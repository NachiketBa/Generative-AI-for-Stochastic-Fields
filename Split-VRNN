class SplitVRNN(nn.Module):
    def __init__(self, input_dim, hidden_dim, z1_dim, z2_dim):
        super(SplitVRNN, self).__init__()
        self.encoder_rnn = nn.GRU(input_dim, hidden_dim, batch_first=True)
        self.ln_enc = nn.LayerNorm(hidden_dim)

        self.fc_enc = nn.Linear(hidden_dim, hidden_dim)
        self.z1_mu = nn.Linear(hidden_dim, z1_dim)
        self.z1_logvar = nn.Linear(hidden_dim, z1_dim)
        self.z2_mu = nn.Linear(hidden_dim, z2_dim)
        self.z2_logvar = nn.Linear(hidden_dim, z2_dim)

        self.decoder_rnn = nn.GRU(z1_dim + z2_dim, hidden_dim, batch_first=True)
        self.ln_dec = nn.LayerNorm(hidden_dim)
        self.fc_dec = nn.Linear(hidden_dim, input_dim)

    def encode(self, x):
        _, h = self.encoder_rnn(x)
        h = h[-1]
        h = self.ln_enc(h)
        h = F.relu(self.fc_enc(h))
        return self.z1_mu(h), self.z1_logvar(h), self.z2_mu(h), self.z2_logvar(h)

    def reparameterize(self, mu, logvar):
        std = torch.exp(0.5 * logvar)
        eps = torch.randn_like(std)
        return mu + eps * std

    def decode(self, z1, z2, seq_len):
        z = torch.cat([z1, z2], dim=-1)
        z = z.unsqueeze(1).repeat(1, seq_len, 1)
        decoded, _ = self.decoder_rnn(z)
        decoded = self.ln_dec(decoded)
        return self.fc_dec(decoded)

    def forward(self, x):
        seq_len = x.size(1)
        z1_mu, z1_logvar, z2_mu, z2_logvar = self.encode(x)
        z1 = self.reparameterize(z1_mu, z1_logvar)
        z2 = self.reparameterize(z2_mu, z2_logvar)
        x_recon = self.decode(z1, z2, seq_len)
        return x_recon, z1_mu, z1_logvar, z2_mu, z2_logvar
def split_vrnn_loss(x_recon, x, z1_mu, z1_logvar, z2_mu, z2_logvar, is_noiseless, lambda_reg):
    recon_loss = F.mse_loss(x_recon, x, reduction='sum')
    kl_z1 = -0.5 * torch.sum(1 + z1_logvar - z1_mu.pow(2) - z1_logvar.exp())
    kl_z2 = -0.5 * torch.sum(1 + z2_logvar - z2_mu.pow(2) - z2_logvar.exp())

    # Only penalize z1 for noiseless samples
    reg_term = lambda_reg * torch.sum((z1_mu.pow(2) + z1_logvar.exp() - 1 - z1_logvar) * (~is_noiseless.bool()).unsqueeze(1))
    return recon_loss + kl_z1 + kl_z2 + reg_term

model = SplitVRNN(input_dim=10, hidden_dim=40, z1_dim=16, z2_dim=16).to(device)
optimizer = optim.Adam(model.parameters(), lr=0.001)
num_epochs = 1000
#
for epoch in range(num_epochs):
    total_loss = 0
    for x, label in trainloader:
        x = x.to(device)
        label = label.to(device)

        optimizer.zero_grad()
        x_recon, z1_mu, z1_logvar, z2_mu, z2_logvar = model(x)
        loss = split_vrnn_loss(x_recon, x, z1_mu, z1_logvar, z2_mu, z2_logvar, label, lambda_reg=1.0)
        loss.backward()
        optimizer.step()

        total_loss += loss.item()

    print(f"Epoch {epoch + 1}: Loss = {total_loss / len(trainloader.dataset):.4f}")

